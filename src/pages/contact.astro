---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact – The IT Guys" description="Contact The IT Guys – Technical Solutions Inc. in Kelowna, British Columbia.">
  <section class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch.</h1>
    <p class="lede">For general inquiries, product support, or privacy-related questions, use the appropriate email below.</p>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <h3>General Inquiries</h3>
        <p><a href="mailto:info@theitguysts.ca">info@theitguysts.ca</a></p>
      </article>
      <article class="card">
        <h3>Product Support</h3>
        <p><a href="mailto:support@theitguysts.ca">support@theitguysts.ca</a></p>
      </article>
      <article class="card">
        <h3>Privacy</h3>
        <p><a href="mailto:privacy@theitguysts.ca">privacy@theitguysts.ca</a></p>
      </article>
    </div>
  </section>

  <section class="section split">
    <div>
      <h2>Location</h2>
    </div>
    <div class="copy">
      <p>The IT Guys – Technical Solutions Inc. is based in Kelowna, British Columbia, Canada.</p>
    </div>
  </section>
</BaseLayout>
