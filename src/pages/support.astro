---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Support – The IT Guys" description="Product support for software and mobile applications developed by The IT Guys – Technical Solutions Inc.">
  <section class="page-hero">
    <p class="eyebrow">Support</p>
    <h1>Product support.</h1>
    <p class="lede">For help with software, mobile applications, or services developed by The IT Guys – Technical Solutions Inc., contact us using the support details below.</p>
  </section>

  <section class="section">
    <div class="grid two">
      <article class="card">
        <h3>App & Product Support</h3>
        <p>For product questions, troubleshooting, or support requests, email <a href="mailto:support@theitguysts.ca">support@theitguysts.ca</a>.</p>
      </article>
      <article class="card">
        <h3>Privacy Questions</h3>
        <p>For privacy-related questions, email <a href="mailto:privacy@theitguysts.ca">privacy@theitguysts.ca</a> or review our <a href="/privacy/">Privacy Policy</a>.</p>
      </article>
    </div>
  </section>

  <section class="section split">
    <div>
      <h2>What to include</h2>
    </div>
    <div class="copy">
      <p>To help us respond efficiently, include the app or product name, your device type, operating system version, and a brief description of the issue or question.</p>
      <p>If the issue involves an error or unexpected behavior, include the steps that led to the problem and any relevant screenshots if available.</p>
    </div>
  </section>

  <section class="section split muted-panel">
    <div>
      <h2>Current status</h2>
    </div>
    <div class="copy">
      <p>Public app-specific support pages will be added as products become available on the App Store and Google Play.</p>
    </div>
  </section>
</BaseLayout>
