---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = 'June 2026';
---
<BaseLayout title="Privacy Policy – The IT Guys" description="Privacy Policy for The IT Guys – Technical Solutions Inc.">
  <section class="page-hero">
    <p class="eyebrow">Privacy Policy</p>
    <h1>Privacy Policy</h1>
    <p class="lede">Last updated: {updated}</p>
  </section>

  <section class="section split">
    <div>
      <h2>How we handle information.</h2>
    </div>
    <div class="copy">
      <p>This privacy policy applies to The IT Guys – Technical Solutions Inc. and this website, theitguysts.ca.</p>
      <p>We collect only the information needed to respond to inquiries or provide requested support. If you contact us by email, we may receive your name, email address, message content, and any other information you choose to provide.</p>
      <p>We do not sell personal information.</p>
      <p>We may use basic website hosting, security, and analytics tools to operate and protect the website. These tools may process standard technical information such as IP address, browser type, device information, and pages visited.</p>
      <p>For privacy-related questions, contact <a href="mailto:privacy@theitguysts.ca">privacy@theitguysts.ca</a>.</p>
      <p>This policy may be updated as our website, products, and applications evolve.</p>
    </div>
  </section>
</BaseLayout>
